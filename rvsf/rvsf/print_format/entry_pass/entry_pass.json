 "doctype": "Print Format",
 "font_size": 14,
 "html": "<style>\n    /* Global Thermal Receipt Reset & Form Factor */\n    .ep-receipt-container {\n        width: 72mm; /* Safe printable width on standard 80mm thermal paper rolls */\n        margin: 0 auto;\n        padding: 2mm 1mm;\n        font-family: \"Courier New\", Courier, monospace, Arial, sans-serif;\n        font-size: 11px;\n        line-height: 1.4;\n        color: #1f2933;\n        background-color: #ffffff;\n        -webkit-print-color-adjust: exact;\n        print-color-adjust: exact;\n    }\n\n    .ep-receipt-container * { \n        box-sizing: border-box; \n    }\n\n    /* Primary Typography & Color Palettes */\n    .ep-bold {\n        font-weight: bold;\n        color: #0b2e4f; /* Dark Blue Brand Palette */\n    }\n    \n    .ep-title-main {\n        font-size: 15px;\n        font-weight: 800;\n        color: #0b2e4f;\n        margin: 4px 0 1px 0;\n        text-transform: uppercase;\n        letter-spacing: 0.5px;\n    }\n\n    .ep-subtitle-sub {\n        font-size: 9.5px;\n        color: #55606b;\n        margin-bottom: 4px;\n        text-transform: uppercase;\n        letter-spacing: 0.3px;\n    }\n\n    .ep-doc-badge {\n        font-size: 15px;\n        font-weight: 800;\n        color: #1b5e20; /* Dark Green Document Context Palette */\n        margin: 6px 0;\n        letter-spacing: 1.5px;\n        text-transform: uppercase;\n    }\n\n    /* Layout Structures using Reliable Native HTML Tables */\n    .ep-data-table {\n        width: 100%;\n        border-collapse: collapse;\n        margin: 4px 0;\n        table-layout: fixed;\n    }\n\n    .ep-data-table td {\n        padding: 3px 0;\n        vertical-align: top;\n        font-size: 11px;\n    }\n\n    .ep-data-label {\n        width: 42%;\n        color: #55606b;\n        text-align: left;\n        font-weight: 700;\n    }\n\n    .ep-data-value {\n        width: 58%;\n        text-align: right;\n        font-weight: bold;\n        word-wrap: break-word;\n    }\n\n    .ep-center {\n        text-align: center;\n    }\n\n    /* Component Dividers */\n    .ep-dashed-line {\n        border-top: 1px dashed #55606b;\n        margin: 6px 0;\n        display: block;\n    }\n\n    /* Header Brand Assets Container */\n    .ep-header-logos {\n        margin-bottom: 6px;\n        text-align: center;\n        width: 100%;\n    }\n    \n    .ep-header-logos table {\n        width: 100%;\n        border-collapse: collapse;\n    }\n\n    .ep-header-logos td {\n        vertical-align: middle;\n        padding: 0;\n    }\n\n    .ep-img-logo-silk {\n        height: 32px !important;\n        width: auto !important;\n        max-width: 100px !important;\n        max-height: 32px !important;\n        display: inline-block;\n    }\n    \n    .ep-img-logo-rvsf {\n        height: 26px !important;\n        width: auto !important;\n        max-width: 90px !important;\n        max-height: 26px !important;\n        display: inline-block;\n    }\n\n    /* Callout & Note Containers */\n    .ep-highlight-notice {\n        border: 1px solid #0b2e4f;\n        background-color: #f6f8fa;\n        padding: 6px;\n        margin: 8px 0;\n        text-align: center;\n        font-size: 9.5px;\n        line-height: 1.35;\n        border-radius: 4px;\n    }\n\n    .ep-footer-text {\n        font-size: 9.5px;\n        color: #55606b;\n        margin-top: 6px;\n        line-height: 1.4;\n    }\n\n    /* Prevention rules for print parser engines */\n    .ep-no-split { page-break-inside: avoid; }\n</style>\n\n{%- set silk_logo_receipt = frappe.db.get_value(\"File\", {\"file_name\": \"image5.jpg\"}, \"file_url\") -%}\n{%- set rvsf_logo_receipt = frappe.db.get_value(\"File\", {\"file_name\": \"image1.jpg\"}, \"file_url\") -%}\n\n{# Safely lookup relative attributes via Gate Pass database if available #}\n{%- set gp_ref = frappe.get_doc(\"Gate Pass\", doc.gate_pass_id) if doc.gate_pass_id else None -%}\n{%- set pl_ref = frappe.db.get_value(\"Purchase Lead\", gp_ref.purchase_lead, \n    [\"maker_name\", \"model_name\", \"vehicle_category\"], as_dict=True) if (gp_ref and gp_ref.purchase_lead) else None -%}\n\n<div class=\"ep-receipt-container\">\n    \n    <!-- ===================== HEADER & LOGOS ===================== -->\n    <div class=\"ep-center ep-no-split\">\n        <div class=\"ep-header-logos\">\n            <table>\n                <tr>\n                    <td style=\"text-align: left; width: 50%;\">\n                        {% if silk_logo_receipt %}\n                            <img class=\"ep-img-logo-silk\" src=\"{{ silk_logo_receipt }}\" alt=\"SILK\">\n                        {% else %}\n                            <span class=\"ep-bold\" style=\"font-size: 14px;\">SILK</span>\n                        {% endif %}\n                    </td>\n                    <td style=\"text-align: right; width: 50%;\">\n                        {% if rvsf_logo_receipt %}\n                            <img class=\"ep-img-logo-rvsf\" src=\"{{ rvsf_logo_receipt }}\" alt=\"RVSF\">\n                        {% else %}\n                            <span class=\"ep-bold\" style=\"color: #1b5e20;\">RVSF</span>\n                        {% endif %}\n                    </td>\n                </tr>\n            </table>\n        </div>\n        \n        <div class=\"ep-title-main\">SILK</div>\n        <div class=\"ep-subtitle-sub\">Registered Vehicle Scrapping Facility</div>\n        <div class=\"ep-doc-badge\">Entry Pass</div>\n    </div>\n\n    <div class=\"ep-dashed-line\"></div>\n\n    <!-- ===================== ENTRY PASS METADATA ===================== -->\n    <table class=\"ep-data-table ep-no-split\">\n        <tr>\n            <td class=\"ep-data-label\">Pass ID:</td>\n            <td class=\"ep-data-value\" style=\"color: #0b2e4f;\">{{ doc.name or \"-\" }}</td>\n        </tr>\n        <tr>\n            <td class=\"ep-data-label\">Gate Pass Ref:</td>\n            <td class=\"ep-data-value\">{{ doc.gate_pass_id or \"-\" }}</td>\n        </tr>\n        {% if gp_ref and gp_ref.purchase_lead %}\n        <tr>\n            <td class=\"ep-data-label\">Purchase Lead:</td>\n            <td class=\"ep-data-value\">{{ gp_ref.purchase_lead }}</td>\n        </tr>\n        {% endif %}\n    </table>\n\n    <div class=\"ep-dashed-line\"></div>\n\n    <!-- ===================== CUSTOMER TRACKING ===================== -->\n    <table class=\"ep-data-table ep-no-split\">\n        <tr>\n            <td class=\"ep-data-label\">Customer:</td>\n            <td class=\"ep-data-value\">{{ doc.visitor_name or \"Not Specified\" }}</td>\n        </tr>\n        {% if doc.contact_no %}\n        <tr>\n            <td class=\"ep-data-label\">Mobile No:</td>\n            <td class=\"ep-data-value\">{{ doc.contact_no }}</td>\n        </tr>\n        {% endif %}\n    </table>\n\n    <div class=\"ep-dashed-line\"></div>\n\n    <!-- ===================== VEHICLE INFORMATION ===================== -->\n    <table class=\"ep-data-table ep-no-split\">\n        <tr>\n            <td class=\"ep-data-label\">Vehicle No:</td>\n            <td class=\"ep-data-value\" style=\"font-size: 12px; color: #1b5e20;\">{{ doc.vehicle or \"-\" }}</td>\n        </tr>\n        <tr>\n            <td class=\"ep-data-label\">Category:</td>\n            <td class=\"ep-data-value\">\n                {{ doc.entry_type if doc.entry_type else (pl_ref.vehicle_category if pl_ref and pl_ref.vehicle_category else \"Not Specified\") }}\n            </td>\n        </tr>\n        {% if pl_ref and pl_ref.maker_name %}\n        <tr>\n            <td class=\"ep-data-label\">Make:</td>\n            <td class=\"ep-data-value\">{{ pl_ref.maker_name }}</td>\n        </tr>\n        {% endif %}\n        {% if pl_ref and pl_ref.model_name %}\n        <tr>\n            <td class=\"ep-data-label\">Model:</td>\n            <td class=\"ep-data-value\">{{ pl_ref.model_name }}</td>\n        </tr>\n        {% endif %}\n    </table>\n\n    <div class=\"ep-dashed-line\"></div>\n\n    <!-- ===================== MOVEMENT LOGISTICS ===================== -->\n    <table class=\"ep-data-table ep-no-split\">\n        <tr>\n            <td class=\"ep-data-label\">Entry Date:</td>\n            <td class=\"ep-data-value\">\n                {{ frappe.utils.formatdate(frappe.utils.getdate(doc.entry_time)) if doc.entry_time else \"-\" }}\n            </td>\n        </tr>\n        <tr>\n            <td class=\"ep-data-label\">Entry Time:</td>\n            <td class=\"ep-data-value\">\n                {{ frappe.utils.format_time(doc.entry_time) if doc.entry_time else \"-\" }}\n            </td>\n        </tr>\n        {% if doc.entry_approved_by_name %}\n        <tr>\n            <td class=\"ep-data-label\">Security Staff:</td>\n            <td class=\"ep-data-value\" style=\"font-weight: normal; font-size: 10px;\">{{ doc.entry_approved_by_name }}</td>\n        </tr>\n        {% endif %}\n    </table>\n\n    <!-- ===================== ACKNOWLEDGEMENT NOTE ===================== -->\n    <div class=\"ep-highlight-notice ep-no-split\">\n        <span class=\"ep-bold\">PLEASE NOTE</span><br/>\n        Please retain this Entry Pass safely. It must be presented during vehicle exit and further processing.\n    </div>\n\n    <div class=\"ep-dashed-line\"></div>\n\n    <!-- ===================== FOOTER RUNTIME ===================== -->\n    <div class=\"ep-center ep-footer-text ep-no-split\">\n        <div class=\"ep-bold\">Thank You</div>\n        <div>Visit Again</div>\n        <div style=\"font-size: 8.5px; margin-top: 2px; color: #55606b;\">Registered Vehicle Scrapping Facility</div>\n    </div>\n\n</div>",
