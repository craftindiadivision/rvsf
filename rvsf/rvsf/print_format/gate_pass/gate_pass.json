 "doctype": "Print Format",
 "font_size": 14,
 "html": "<style>\n  /* ===================== BASE ===================== */\n  #gate-pass-print {\n    font-family: \"Helvetica Neue\", Arial, \"Segoe UI\", sans-serif;\n    color: #1f2933;\n    font-size: 10.5px;\n    line-height: 1.45;\n    background: #ffffff;\n    -webkit-print-color-adjust: exact;\n    print-color-adjust: exact;\n  }\n\n  #gate-pass-print * { box-sizing: border-box; }\n\n  #gate-pass-print table {\n    border-collapse: collapse;\n    width: 100%;\n    table-layout: fixed;\n  }\n\n  @page { size: A4; margin: 14mm 12mm; }\n\n  /* ===================== HEADER ===================== */\n  .gp-header {\n    border-bottom: 3px solid #0b2e4f;\n    padding-bottom: 10px;\n    margin-bottom: 10px;\n  }\n  .gp-header table { table-layout: auto; }\n  .gp-header-cell { vertical-align: middle; padding: 0; }\n  .gp-brand-left  { width: 32%; text-align: left; }\n  .gp-brand-mid   { width: 36%; text-align: center; }\n  .gp-brand-right { width: 32%; text-align: right; }\n\n  .gp-logo-silk {\n    height: 46px !important;\n    width: auto !important;\n    max-width: 160px !important;\n    max-height: 46px !important;\n    display: inline-block;\n  }\n  .gp-logo-rvsf {\n    height: 34px !important;\n    width: auto !important;\n    max-width: 140px !important;\n    max-height: 34px !important;\n    display: inline-block;\n  }\n\n  .gp-doc-title {\n    font-size: 20px;\n    font-weight: 800;\n    color: #1b5e20;\n    text-transform: uppercase;\n    letter-spacing: 1px;\n    white-space: nowrap;\n  }\n  .gp-doc-subtitle {\n    font-size: 9.5px;\n    color: #55606b;\n    margin-top: 2px;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    white-space: nowrap;\n  }\n  .gp-rvsf-tag {\n    display: inline-block;\n    margin-top: 5px;\n    font-size: 9px;\n    font-weight: 700;\n    color: #1b5e20;\n    background: #e8f3e9;\n    border: 1px solid #2e7d32;\n    border-radius: 10px;\n    padding: 2px 10px;\n    letter-spacing: 0.4px;\n  }\n\n  /* ===================== GATE PASS INFO STRIP ===================== */\n  .gp-meta-strip {\n    background: #eaf1f8;\n    border: 1px solid #d9dde3;\n    border-radius: 6px;\n    margin-bottom: 14px;\n  }\n  .gp-meta-cell {\n    padding: 8px 12px;\n    border-right: 1px solid #d9dde3;\n    vertical-align: middle;\n    width: 33.33%;\n  }\n  .gp-meta-cell.last { border-right: none; }\n  .gp-meta-label {\n    font-size: 8px;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    color: #55606b;\n    font-weight: 700;\n    margin-bottom: 2px;\n  }\n  .gp-meta-value {\n    font-size: 13px;\n    font-weight: 800;\n    color: #0b2e4f;\n  }\n\n  /* ===================== SECTIONS ===================== */\n  .gp-section { margin-bottom: 12px; }\n  .gp-section-header {\n    background-color: #123a63;\n    background-image: linear-gradient(90deg, #0b2e4f 0%, #123a63 70%, #1b5e20 100%);\n    color: #fff;\n    padding: 5px 12px;\n    border-radius: 5px;\n    font-size: 10.5px;\n    font-weight: 700;\n    letter-spacing: 0.4px;\n    text-transform: uppercase;\n    margin-bottom: 6px;\n  }\n\n  /* ===================== FIELD GRID (label / value rows) ===================== */\n  .gp-field-grid {\n    border: 1px solid #d9dde3;\n    border-radius: 4px;\n  }\n  .gp-field-grid tr:nth-child(even) td { background: #f6f8fa; }\n  .gp-field-cell {\n    padding: 5px 10px;\n    border-bottom: 1px solid #d9dde3;\n    vertical-align: top;\n    width: 50%;\n  }\n  .gp-field-grid tr:last-child .gp-field-cell { border-bottom: none; }\n  .gp-field-cell.full { width: 100%; }\n  .gp-field-label {\n    font-weight: 700;\n    color: #0b2e4f;\n    display: inline-block;\n    min-width: 2%;\n    font-size: 9.7px;\n  }\n  .gp-field-value {\n    color: #1f2933;\n    font-size: 10px;\n  }\n  .gp-field-value.empty { color: #9aa5b1; font-style: italic; }\n\n  /* ===================== APPOINTMENT HIGHLIGHT (blue theme) ===================== */\n  .gp-appointment-box {\n    border: 1.5px solid #123a63;\n    border-radius: 4px;\n    background: #eaf1f8;\n  }\n  .gp-appointment-box tr:nth-child(even) td { background: #dfe9f5; }\n  .gp-appointment-cell {\n    padding: 8px 10px;\n    border-bottom: 1px solid #c7d5e6;\n    text-align: center;\n    vertical-align: middle;\n    width: 33.33%;\n  }\n  .gp-appointment-box tr:last-child .gp-appointment-cell { border-bottom: none; }\n  .gp-appointment-label {\n    display: block;\n    font-size: 8.5px;\n    font-weight: 700;\n    color: #123a63;\n    text-transform: uppercase;\n    letter-spacing: 0.4px;\n    margin-bottom: 3px;\n  }\n  .gp-appointment-value {\n    font-size: 13px;\n    font-weight: 800;\n    color: #0b2e4f;\n  }\n\n  /* ===================== INSTRUCTIONS BOX ===================== */\n  .gp-instructions-box {\n    border: 1px solid #d9dde3;\n    border-left: 4px solid #123a63;\n    border-radius: 4px;\n    background: #f6f8fa;\n    padding: 10px 14px;\n  }\n  .gp-instructions-box ul {\n    margin: 0;\n    padding-left: 16px;\n  }\n  .gp-instructions-box li {\n    font-size: 9.5px;\n    color: #333f4a;\n    line-height: 1.7;\n  }\n\n  /* ===================== DECLARATION BOX ===================== */\n  .gp-declaration-box {\n    border: 1px solid #d9dde3;\n    border-left: 4px solid #55606b;\n    border-radius: 4px;\n    background: #f6f8fa;\n    padding: 8px 14px;\n    font-size: 9px;\n    color: #55606b;\n    font-style: italic;\n    line-height: 1.6;\n  }\n\n  /* ===================== SIGNATURE BLOCK ===================== */\n  .gp-signature-box {\n    border: 1px solid #d9dde3;\n    border-radius: 4px;\n    padding: 10px 14px;\n  }\n  .gp-signature-image {\n    max-height: 55px !important;\n    max-width: 200px !important;\n    height: auto !important;\n    width: auto !important;\n    display: block;\n    margin-bottom: 6px;\n  }\n  .gp-signature-line {\n    border-top: 1px solid #1f2933;\n    width: 200px;\n    margin-top: 34px;\n    margin-bottom: 4px;\n  }\n  .gp-signature-caption {\n    font-size: 9px;\n    font-weight: 700;\n    color: #0b2e4f;\n    text-transform: uppercase;\n    letter-spacing: 0.3px;\n  }\n\n  /* keep sections from splitting awkwardly across a PDF page break */\n  .gp-avoid-break { page-break-inside: avoid; }\n</style>\n\n{%- set silk_logo = frappe.db.get_value(\"File\", {\"file_name\": \"image5.jpg\"}, \"file_url\") -%}\n{%- set rvsf_logo = frappe.db.get_value(\"File\", {\"file_name\": \"image1.jpg\"}, \"file_url\") -%}\n{%- set pl = frappe.db.get_value(\"Purchase Lead\", doc.purchase_lead,\n      [\"owner_name\", \"mobile_number\", \"address1\", \"address2\", \"address3\", \"district\", \"state\", \"pin_code\",\n       \"vehicle_registration_no\", \"maker_name\", \"model_name\", \"vehicle_category\", \"fuel_type\", \"rc_weight\"],\n      as_dict=True) if doc.purchase_lead else None -%}\n{%- set pl_addr_parts = [] -%}\n{%- if pl and pl.address1 %}{% set _ = pl_addr_parts.append(pl.address1) %}{% endif -%}\n{%- if pl and pl.address2 %}{% set _ = pl_addr_parts.append(pl.address2) %}{% endif -%}\n{%- if pl and pl.address3 %}{% set _ = pl_addr_parts.append(pl.address3) %}{% endif -%}\n\n<div id=\"gate-pass-print\">\n\n  <!-- ============================================================ -->\n  <!-- HEADER                                                        -->\n  <!-- ============================================================ -->\n  <div class=\"gp-header gp-avoid-break\">\n    <table>\n      <tr>\n        <td class=\"gp-header-cell gp-brand-left\">\n          <img class=\"gp-logo-silk\" src=\"{{ silk_logo or '/files/image5.jpg' }}\" width=\"120\" height=\"46\">\n        </td>\n        <td class=\"gp-header-cell gp-brand-mid\">\n          <div class=\"gp-doc-title\">Gate Pass</div>\n          <div class=\"gp-doc-subtitle\">Registered Vehicle Scrapping Facility (RVSF)</div>\n          <div class=\"gp-rvsf-tag\">RVSF Department</div>\n        </td>\n        <td class=\"gp-header-cell gp-brand-right\">\n          <img class=\"gp-logo-rvsf\" src=\"{{ rvsf_logo or '/files/image1.jpg' }}\" alt=\"RVSF\" width=\"105\" height=\"34\">\n        </td>\n      </tr>\n    </table>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- GATE PASS INFORMATION                                         -->\n  <!-- ============================================================ -->\n  <table class=\"gp-meta-strip gp-avoid-break\">\n    <tr>\n      <td class=\"gp-meta-cell\">\n        <div class=\"gp-meta-label\">Gate Pass No</div>\n        <div class=\"gp-meta-value\">{{ doc.name or \"-\" }}</div>\n      </td>\n      <td class=\"gp-meta-cell\">\n        <div class=\"gp-meta-label\">Date</div>\n        <div class=\"gp-meta-value\">{{ frappe.utils.formatdate(doc.posting_date) if doc.posting_date else \"-\" }}</div>\n      </td>\n      <td class=\"gp-meta-cell last\">\n        <div class=\"gp-meta-label\">Company</div>\n        <div class=\"gp-meta-value\">{{ doc.company or \"-\" }}</div>\n      </td>\n    </tr>\n  </table>\n\n  <!-- ============================================================ -->\n  <!-- CUSTOMER DETAILS                                              -->\n  <!-- ============================================================ -->\n  <div class=\"gp-section gp-avoid-break\">\n    <div class=\"gp-section-header\">Customer Details</div>\n    <table class=\"gp-field-grid\">\n      <tr>\n        <td class=\"gp-field-cell\"><span class=\"gp-field-label\">Customer Name:</span>\n          <span class=\"gp-field-value {{ 'empty' if not (pl and pl.owner_name) }}\">{{ pl.owner_name if pl and pl.owner_name else (doc.supplier or \"Not specified\") }}</span>\n        </td>\n        <td class=\"gp-field-cell\"><span class=\"gp-field-label\">Mobile Number:</span>\n          <span class=\"gp-field-value {{ 'empty' if not (pl and pl.mobile_number) }}\">{{ pl.mobile_number if pl and pl.mobile_number else \"Not specified\" }}</span>\n        </td>\n      </tr>\n      <tr>\n        <td class=\"gp-field-cell full\" colspan=\"2\"><span class=\"gp-field-label\">Address:</span>\n          <span class=\"gp-field-value {{ 'empty' if not pl_addr_parts }}\">{{ pl_addr_parts | join(\", \") if pl_addr_parts else \"Not provided\" }}</span>\n        </td>\n      </tr>\n      <tr>\n        <td class=\"gp-field-cell\"><span class=\"gp-field-label\">District:</span>\n          <span class=\"gp-field-value {{ 'empty' if not (pl and pl.district) }}\">{{ pl.district if pl and pl.district else \"Not provided\" }}</span>\n        </td>\n        <td class=\"gp-field-cell\"><span class=\"gp-field-label\">State:</span>\n          <span class=\"gp-field-value {{ 'empty' if not (pl and pl.state) }}\">{{ pl.state if pl and pl.state else \"Not provided\" }}</span>\n        </td>\n      </tr>\n      <tr>\n        <td class=\"gp-field-cell\"><span class=\"gp-field-label\">PIN Code:</span>\n          <span class=\"gp-field-value {{ 'empty' if not (pl and pl.pin_code) }}\">{{ pl.pin_code if pl and pl.pin_code else \"Not provided\" }}</span>\n        </td>\n        <td class=\"gp-field-cell\"></td>\n      </tr>\n    </table>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- VEHICLE DETAILS                                               -->\n  <!-- ============================================================ -->\n  <div class=\"gp-section gp-avoid-break\">\n    <div class=\"gp-section-header\">Vehicle Details</div>\n    <table class=\"gp-field-grid\">\n      <tr>\n        <td class=\"gp-field-cell\"><span class=\"gp-field-label\">Registration No:</span>\n          <span class=\"gp-field-value {{ 'empty' if not (pl and pl.vehicle_registration_no) }}\">{{ pl.vehicle_registration_no if pl and pl.vehicle_registration_no else \"Not available\" }}</span>\n        </td>\n        <td class=\"gp-field-cell\"><span class=\"gp-field-label\">Maker Name:</span>\n          <span class=\"gp-field-value {{ 'empty' if not (pl and pl.maker_name) }}\">{{ pl.maker_name if pl and pl.maker_name else \"Not specified\" }}</span>\n        </td>\n      </tr>\n      <tr>\n        <td class=\"gp-field-cell\"><span class=\"gp-field-label\">Model Name:</span>\n          <span class=\"gp-field-value {{ 'empty' if not (pl and pl.model_name) }}\">{{ pl.model_name if pl and pl.model_name else \"Not specified\" }}</span>\n        </td>\n        <td class=\"gp-field-cell\"><span class=\"gp-field-label\">Vehicle Category:</span>\n          <span class=\"gp-field-value {{ 'empty' if not (pl and pl.vehicle_category) }}\">{{ pl.vehicle_category if pl and pl.vehicle_category else \"Not specified\" }}</span>\n        </td>\n      </tr>\n      <tr>\n        <td class=\"gp-field-cell\"><span class=\"gp-field-label\">Fuel Type:</span>\n          <span class=\"gp-field-value {{ 'empty' if not (pl and pl.fuel_type) }}\">{{ pl.fuel_type if pl and pl.fuel_type else \"Not specified\" }}</span>\n        </td>\n        <td class=\"gp-field-cell\"><span class=\"gp-field-label\">Unladen Weight:</span>\n          <span class=\"gp-field-value {{ 'empty' if not (pl and pl.rc_weight) }}\">{{ \"%.2f\"|format(pl.rc_weight) ~ \" kg\" if pl and pl.rc_weight else \"Not provided\" }}</span>\n        </td>\n      </tr>\n    </table>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- APPOINTMENT DETAILS                                           -->\n  <!-- ============================================================ -->\n  <div class=\"gp-section gp-avoid-break\">\n    <div class=\"gp-section-header\">Appointment Details</div>\n    <table class=\"gp-appointment-box\">\n      <tr>\n        <td class=\"gp-appointment-cell\">\n          <span class=\"gp-appointment-label\">Scheduled Date</span>\n          <span class=\"gp-appointment-value\">{{ frappe.utils.formatdate(doc.scheduled_date) if doc.scheduled_date else \"Not scheduled\" }}</span>\n        </td>\n        \n        <td class=\"gp-appointment-cell\">\n          <span class=\"gp-appointment-label\">Reporting Time</span>\n          <span class=\"gp-appointment-value\">\n            {%- if doc.start_time and doc.end_time -%}\n              {{ frappe.utils.format_time(doc.start_time) }} - {{ frappe.utils.format_time(doc.end_time) }}\n            {%- else -%}\n              Not specified\n            {%- endif -%}\n          </span>\n        </td>\n      </tr>\n    </table>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- IMPORTANT INSTRUCTIONS                                        -->\n  <!-- ============================================================ -->\n  <div class=\"gp-section gp-avoid-break\">\n    <div class=\"gp-section-header\">Important Instructions</div>\n    <div class=\"gp-instructions-box\">\n      <ul>\n        <li>Carry this Gate Pass while visiting the facility.</li>\n        <li>Carry original RC Book and supporting documents.</li>\n        <li>Reach the facility during your allotted time slot.</li>\n        <li>Follow all safety instructions provided by RVSF staff.</li>\n        <li>Entry is subject to successful verification of documents.</li>\n        <li>Vehicles arriving outside the allotted slot may experience delays.</li>\n      </ul>\n    </div>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- DECLARATION                                                   -->\n  <!-- ============================================================ -->\n  <div class=\"gp-section gp-avoid-break\">\n    <div class=\"gp-declaration-box\">\n      This Gate Pass is issued for facilitating vehicle entry into the RVSF facility. It does not confirm ownership transfer or completion of the scrapping process.\n    </div>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- AUTHORIZED SIGNATORY                                          -->\n  <!-- ============================================================ -->\n\n\n</div>",
