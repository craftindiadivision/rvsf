 "html": "<div class=\"vshv-wrapper\">\n  <style>\n    /* Legacy-compatible print safe CSS (wkhtmltopdf friendly) */\n    .vshv-wrapper, .vshv-wrapper * {\n      -webkit-print-color-adjust: exact !important;\n      print-color-adjust: exact !important;\n      color-adjust: exact !important;\n      box-sizing: border-box;\n    }\n    \n    .vshv-wrapper {\n      font-family: \"Segoe UI\", Arial, sans-serif;\n      color: #1c2b39;\n      font-size: 12px;\n      width: 100%;\n      background-color: #ffffff;\n      border: 1.5px solid #102e4d;\n      border-radius: 4px;\n      overflow: hidden;\n    }\n\n    /* ---------- Unified Centered Header Block ---------- */\n    .vshv-header-table {\n      width: 100%;\n      border-collapse: collapse;\n      table-layout: fixed;\n      background: #102e4d; /* Fallback */\n      background: linear-gradient(135deg, #102e4d 0%, #113426 100%);\n    }\n    \n    .vshv-header-cell {\n      padding: 16px 20px;\n      text-align: left;\n      vertical-align: middle;\n    }\n\n    /* Logo & Title Left alignment wrapper */\n    .vshv-logo-shield {\n      width: 32px;\n      height: 32px;\n      border: 2.5px solid #ffffff;\n      border-radius: 8px 8px 8px 0;\n      transform: rotate(45deg);\n      display: inline-block;\n      margin-right: 15px;\n      vertical-align: middle;\n    }\n    \n    .vshv-title-text-wrap {\n      display: inline-block;\n      vertical-align: middle;\n    }\n\n    /* Increased Main Title Font Size */\n    .vshv-main-title {\n      color: #ffffff;\n      font-size: 22px; \n      font-weight: 800;\n      line-height: 1.25;\n      letter-spacing: 0.6px;\n    }\n\n    /* Yard Operations Checklist centered on the right relative to title block height */\n    .vshv-subtitle-cell {\n      width: 200px;\n      padding: 16px 20px;\n      text-align: right;\n      vertical-align: middle;\n    }\n\n    .vshv-subtitle {\n      color: #9abfdc;\n      font-size: 13.5px;\n      font-weight: bold;\n      letter-spacing: 0.2px;\n      margin-top: 10px;\n    }\n\n    /* ---------- Section Title Bars ---------- */\n    .vshv-section-bar {\n      background-color: #1e4976;\n      color: #ffffff;\n      font-size: 12px;\n      font-weight: bold;\n      padding: 7px 12px;\n      letter-spacing: 0.3px;\n    }\n\n    /* ---------- Data Tables ---------- */\n    .vshv-grid-table {\n      width: 100%;\n      border-collapse: collapse;\n      table-layout: fixed;\n    }\n\n    .vshv-grid-table td, \n    .vshv-grid-table th {\n      border: 1px solid #b8c7d5;\n      padding: 7px 10px;\n      font-size: 12px;\n      vertical-align: middle;\n      text-align: left;\n      \n    }\n\n    /* Info Table Column Layouts */\n    .vshv-info-col {\n      width: 50%;\n    }\n\n    .vshv-bold-label {\n      font-weight: bold;\n      color: #102e4d;\n    }\n\n    /* ---------- Checklist Layout (Dark Blue Headers) ---------- */\n    .vshv-checklist-th {\n      background-color: blue !important; /* Force exact matching Dark Blue */\n      color: #ffffff !important;\n      font-weight: bold;\n      border: 1px solid #0a1f34 !important;\n    }\n\n    .vshv-col-idx { width: 6%; text-align: center !important; }\n    .vshv-col-ques { width: 42%; }\n    .vshv-col-resp { width: 26%; }\n    .vshv-col-reason { width: 26%; }\n\n    .vshv-row-even {\n      background-color: #f5f8fa;\n    }\n\n    /* ---------- UPGRADED Absolute Centered Radio Button Styling ---------- */\n    .vshv-radio-option-inline {\n      display: inline-block;\n      margin-right: 15px;\n      vertical-align: middle;\n    }\n\n    .vshv-radio-outer {\n      width: 14px;\n      height: 14px;\n      border: 1.5px solid #102e4d;\n      border-radius: 50%;\n      display: inline-block;\n      vertical-align: middle;\n      margin-right: 6px;\n      background-color: #ffffff;\n      position: relative; /* Setup relative base for absolute centered child */\n    }\n\n    .vshv-radio-inner-dot {\n      width: 6px;\n      height: 6px;\n      background-color: #102e4d;\n      border-radius: 50%;\n      position: absolute;\n      top: 50%;\n      left: 50%;\n      margin-top: -3px; /* Exact half of inner height to center vertically */\n      margin-left: -3px; /* Exact half of inner width to center horizontally */\n      display: block;\n    }\n\n    .vshv-radio-text {\n      font-size: 12px;\n      color: #1c2b39;\n      display: inline-block;\n      vertical-align: middle;\n    }\n\n    /* ---------- Verdict Section ---------- */\n    .vshv-verdict-label-col {\n      width: 35%;\n      font-weight: bold;\n      color: #102e4d;\n    }\n\n    .vshv-verdict-val-col {\n      width: 65%;\n    }\n\n    .vshv-verdict-table td {\n      padding: 9px 10px;\n    }\n\n    /* ---------- Footer block styled in Dark Blue ---------- */\n    .vshv-footer-block {\n      padding: 10px 12px;\n      font-size: 11px;\n      color: white; /* Force Dark Blue brand color */\n      background-color:  #102e4d;\n      font-weight: bold;\n      font-style: italic;\n    }\n    .vshv-grid-table > thead > tr > th {\n    background: #1e4976 !important;\n    color: white !important;\n}\n  </style>\n\n  <table class=\"vshv-header-table\">\n    <tr>\n      <td class=\"vshv-header-cell\">\n        <span class=\"vshv-logo-shield\"></span>\n        <div class=\"vshv-title-text-wrap\">\n          <div class=\"vshv-main-title\">VEHICLE SECURITY &amp; HAZARD</div>\n          <div class=\"vshv-main-title\">VERIFICATION FORM</div>\n        </div>\n      </td>\n      <td class=\"vshv-subtitle-cell\">\n        <div class=\"vshv-subtitle\">Yard Operations Checklist</div>\n      </td>\n    </tr>\n  </table>\n\n  <div class=\"vshv-section-bar\">General Information</div>\n  <table class=\"vshv-grid-table\">\n    <colgroup>\n      <col class=\"vshv-info-col\" />\n      <col class=\"vshv-info-col\" />\n    </colgroup>\n    <tr>\n      <td>\n        <span class=\"vshv-bold-label\">Inspection Date &amp; Time:</span> \n        <span>[{{ frappe.utils.format_datetime(doc.inspection_date_time, \"dd-MMM-yyyy hh:mm a\") if doc.inspection_date_time else \"\" }}]</span>\n      </td>\n      <td>\n        <span class=\"vshv-bold-label\">Vehicle Registration:</span> \n        <span>[{{ doc.vehicle_no or \"\" }}]</span>\n      </td>\n    </tr>\n    <tr>\n      <td>\n        <span class=\"vshv-bold-label\">Chassis/VIN #:</span> \n        <span>[{{ doc.chassis_no or \"\" }}]</span>\n      </td>\n      <td>\n        <span class=\"vshv-bold-label\">Inspector:</span> \n        <span>[{{ doc.inspector or \"\" }}]</span>\n      </td>\n    </tr>\n  </table>\n\n  <div class=\"vshv-section-bar\">PHYSICAL &amp; SECURITY VERIFICATION CHECKLIST (Yes/No)</div>\n  <table class=\"vshv-grid-table\">\n    <thead >\n      <tr >\n        <th class=\"vshv-checklist-th vshv-col-idx\">#</th>\n        <th class=\"vshv-checklist-th vshv-col-ques\">Inspection Question</th>\n        <th class=\"vshv-checklist-th vshv-col-resp\">Response</th>\n        <th class=\"vshv-checklist-th vshv-col-reason\">Reason for Check</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% for row in doc.security_verification_form %}\n      <tr class=\"{{ 'vshv-row-even' if loop.index % 2 == 0 else '' }}\">\n        <td class=\"vshv-col-idx\">{{ loop.index }}</td>\n        <td class=\"vshv-col-ques\">{{ row.inspection_question }}</td>\n        <td class=\"vshv-col-resp\">\n          {% set current_resp = row.response %}\n          \n          {# Decide dynamically whether this row supports N/A + No OR Yes + No #}\n          {% if current_resp == \"N/A\" %}\n            {% set options_list = [\"N/A\", \"No\"] %}\n          {% else %}\n            {% set options_list = [\"Yes\", \"No\"] %}\n          {% endif %}\n\n          {% for opt in options_list %}\n          <span class=\"vshv-radio-option-inline\">\n            <span class=\"vshv-radio-outer\">\n              {% if current_resp == opt %}\n              <span class=\"vshv-radio-inner-dot\"></span>\n              {% endif %}\n            </span>\n            <span class=\"vshv-radio-text\">{{ opt }}</span>\n          </span>\n          {% endfor %}\n        </td>\n        <td class=\"vshv-col-reason\">{{ row.reason_for_check or \"\" }}</td>\n      </tr>\n      {% endfor %}\n    </tbody>\n  </table>\n\n  <div class=\"vshv-section-bar\">Final Verdict</div>\n  <table class=\"vshv-grid-table vshv-verdict-table\">\n    <tr>\n      <td class=\"vshv-verdict-label-col\">Clear for Yard Entry?</td>\n      <td class=\"vshv-verdict-val-col\">\n        <span class=\"vshv-radio-option-inline\">\n          <span class=\"vshv-radio-outer\">\n            {% if doc.clear_for_yard_entry_ %}\n            <span class=\"vshv-radio-inner-dot\"></span>\n            {% endif %}\n          </span>\n          <span class=\"vshv-radio-text\">Yes (Pass)</span>\n        </span>\n      </td>\n    </tr>\n    <tr>\n      <td class=\"vshv-verdict-label-col\" style=\"vertical-align: top;\">Notes / Rejection Reason:</td>\n      <td class=\"vshv-verdict-val-col\" style=\"vertical-align: top;\">\n        [{{ doc.notes__rejection_reason or \"\" }}]\n      </td>\n    </tr>\n  </table>\n\n  <div class=\"vshv-footer-block\">\n    Audit Trail ID: {{ doc.name or \"\" }}\n  </div>\n</div>",
