{
 "absolute_value": 0,
 "align_labels_right": 0,
 "creation": "2026-07-17 14:52:18.419088",
 "custom_format": 1,
 "default_print_language": "en",
 "disabled": 0,
 "doc_type": "Physical Verification",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<style>\n    /* ==================================================================== */\n    /* GLOBAL LAYOUT & TYPOGRAPHY                                           */\n    /* ==================================================================== */\n    .pv-container {\n        width: 100%;\n        max-width: 800px;\n        margin: 0 auto;\n        padding: 10px;\n        font-family: Arial, sans-serif;\n        font-size: 11px;\n        line-height: 1.35;\n        color: #2d3748;\n        background-color: #ffffff;\n        -webkit-print-color-adjust: exact;\n        print-color-adjust: exact;\n    }\n\n    .pv-container * {\n        box-sizing: border-box;\n    }\n\n    /* Prevent page break splitting inside logical blocks */\n    .pv-no-split {\n        page-break-inside: avoid;\n    }\n\n    /* ==================================================================== */\n    /* COLOR SCHEME & TYPOGRAPHY UTILITES                                   */\n    /* ==================================================================== */\n    .pv-brand-primary { color: #0b2e4f; }       /* Dark Blue */\n    .pv-brand-secondary { color: #123a63; }     /* Medium Blue */\n    .pv-brand-success { color: #1b5e20; }       /* Dark Green */\n    .pv-brand-accent { color: #2e7d32; }        /* Accent Green */\n\n    .pv-font-bold { font-weight: bold; }\n    .pv-text-center { text-align: center; }\n    .pv-text-right { text-align: right; }\n    .pv-text-left { text-align: left; }\n\n    /* ==================================================================== */\n    /* HEADER STYLING                                                       */\n    /* ==================================================================== */\n    .pv-header-table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-bottom: 12px;\n    }\n\n    .pv-header-table td {\n        vertical-align: middle;\n        padding: 0;\n    }\n\n    .pv-logo-left {\n        text-align: left;\n        width: 25%;\n    }\n\n    .pv-logo-right {\n        text-align: right;\n        width: 25%;\n    }\n\n    .pv-title-center {\n        text-align: center;\n        width: 50%;\n    }\n\n    .pv-logo-img {\n        max-height: 48px;\n        width: auto;\n        display: inline-block;\n    }\n\n    .pv-title-main {\n        font-size: 16px;\n        font-weight: 800;\n        color: #0b2e4f;\n        margin: 0;\n        text-transform: uppercase;\n        letter-spacing: 0.75px;\n    }\n\n    .pv-title-sub {\n        font-size: 10px;\n        font-weight: bold;\n        color: #55606b;\n        margin: 2px 0 0 0;\n        text-transform: uppercase;\n        letter-spacing: 0.5px;\n    }\n\n    /* ==================================================================== */\n    /* SECTION HEADER STYLE                                                 */\n    /* ==================================================================== */\n    .pv-section-header {\n        background-color: #0b2e4f;\n        color: #ffffff;\n        font-size: 11px;\n        font-weight: bold;\n        text-transform: uppercase;\n        padding: 4px 8px;\n        margin-top: 10px;\n        margin-bottom: 4px;\n        letter-spacing: 0.5px;\n        border-radius: 2px;\n    }\n\n    /* ==================================================================== */\n    /* DATA TABLES & GRID SYSTEM (WITH BORDERS)                             */\n    /* ==================================================================== */\n    .pv-data-table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-bottom: 4px;\n        border: 1px solid #0b2e4f;\n    }\n\n    .pv-data-table td {\n        padding: 4px 6px;\n        font-size: 11px;\n        vertical-align: top;\n        border: 1px solid #0b2e4f;\n    }\n\n    .pv-label {\n        color: #0b2e4f;\n        font-weight: bold;\n        width: 35%;\n        background-color: #f7fafc;\n    }\n\n    .pv-value {\n        color: #1a202c;\n        width: 65%;\n    }\n\n    /* Shared layout structure (two equal columns) */\n    .pv-grid-table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-bottom: 4px;\n        table-layout: fixed;\n    }\n\n    .pv-grid-table td.pv-col {\n        width: 50%;\n        padding: 0 4px;\n        vertical-align: top;\n    }\n\n    /* Vertical divider rule styling */\n    .pv-dashed-divider {\n        border-top: 1px dashed #cbd5e0;\n        margin: 6px 0;\n    }\n\n    /* ==================================================================== */\n    /* PHYSICAL INSPECTION CHILD TABLE                                      */\n    /* ==================================================================== */\n    .pv-inspection-table {\n        width: 100%;\n        border-collapse: collapse;\n        margin: 4px 0 8px 0;\n        border: 1px solid #0b2e4f;\n    }\n\n    .pv-inspection-table th {\n        background-color: #f0f4f8;\n        border: 1px solid #0b2e4f;\n        color: #0b2e4f;\n        font-size: 10.5px;\n        font-weight: bold;\n        text-transform: uppercase;\n        padding: 4px 8px;\n        text-align: left;\n    }\n\n    .pv-inspection-table td {\n        padding: 4px 8px;\n        border: 1px solid #0b2e4f;\n        font-size: 10.5px;\n        vertical-align: middle;\n    }\n\n    .pv-inspection-table tr:nth-child(even) {\n        background-color: #fafdff;\n    }\n\n    .pv-empty-state {\n        text-align: center;\n        padding: 12px;\n        font-style: italic;\n        color: #718096;\n        border: 1px dashed #cbd5e0;\n        margin: 4px 0;\n        border-radius: 4px;\n    }\n\n    /* ==================================================================== */\n    /* GENERAL OBSERVATIONS / TEXT WRAPPERS                                  */\n    /* ==================================================================== */\n    .pv-observation-box {\n        border: 1px solid #0b2e4f;\n        background-color: #fcfcfc;\n        padding: 6px 10px;\n        font-size: 10.5px;\n        border-radius: 4px;\n        min-height: 38px;\n        margin-top: 4px;\n    }\n\n    /* ==================================================================== */\n    /* SUMMARY HIGHLIGHT BOX                                                */\n    /* ==================================================================== */\n    .pv-summary-card {\n        border: 1.5px solid #0b2e4f;\n        background-color: #f0f4f8;\n        border-radius: 4px;\n        padding: 8px;\n        margin: 10px 0;\n    }\n\n    .pv-summary-card table {\n        width: 100%;\n        border-collapse: collapse;\n    }\n\n    .pv-summary-card td {\n        padding: 2px 6px;\n        font-size: 11px;\n    }\n\n    /* ==================================================================== */\n    /* DECLARATION, ACKNOWLEDGEMENT, & SIGNATURE AREA                      */\n    /* ==================================================================== */\n    .pv-declaration-card {\n        border: 1px solid #1b5e20;\n        background-color: #f4faf4;\n        border-radius: 4px;\n        padding: 10px;\n        margin: 12px 0;\n    }\n\n    .pv-declaration-text {\n        font-size: 10px;\n        line-height: 1.45;\n        text-align: justify;\n        color: #2d3748;\n        margin-bottom: 10px;\n    }\n\n    .pv-signature-container {\n        width: 100%;\n        border-collapse: collapse;\n        margin-top: 8px;\n    }\n\n    .pv-signature-img-wrap {\n        height: 48px;\n        vertical-align: bottom;\n        padding-bottom: 4px;\n    }\n\n    .pv-signature-img {\n        max-height: 44px;\n        max-width: 150px;\n        display: block;\n    }\n\n    .pv-signature-line {\n        border-bottom: 1px solid #718096;\n        width: 180px;\n        margin-bottom: 3px;\n    }\n\n    /* ==================================================================== */\n    /* WORKFLOW APPROVAL COLUMNS                                            */\n    /* ==================================================================== */\n    .pv-approval-table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-top: 12px;\n        table-layout: fixed;\n        border: 1px solid #123a63;\n    }\n\n    .pv-approval-table td {\n        width: 33.33%;\n        padding: 8px;\n        vertical-align: top;\n        text-align: center;\n        border: 1px solid #123a63;\n    }\n\n    .pv-approval-title {\n        font-size: 10px;\n        font-weight: bold;\n        text-transform: uppercase;\n        color: #55606b;\n        margin-bottom: 2px;\n    }\n\n    .pv-approval-name {\n        font-size: 11px;\n        font-weight: bold;\n        color: #0b2e4f;\n        min-height: 14px;\n        margin-bottom: 15px;\n    }\n\n    .pv-approval-sign-line {\n        border-top: 1px solid #a0aec0;\n        width: 130px;\n        margin: 0 auto 3px auto;\n    }\n\n    .pv-approval-sign-label {\n        font-size: 8.5px;\n        color: #718096;\n        text-transform: uppercase;\n    }\n</style>\n\n{# --- SYSTEM FILE RETRIEVAL LOGIC --- #}\n{%- set silk_logo = frappe.db.get_value(\"File\", {\"file_name\": \"image5.jpg\"}, \"file_url\") -%}\n{%- set rvsf_logo = frappe.db.get_value(\"File\", {\"file_name\": \"image1.jpg\"}, \"file_url\") -%}\n\n{# --- DYNAMIC REFERENCED DOCUMENT DATA RETRIEVAL --- #}\n{%- set pl_ref = frappe.get_doc(\"Purchase Lead\", doc.purchase_lead) if doc.purchase_lead else None -%}\n{%- set gp_ref = frappe.get_doc(\"Gate Pass\", doc.gate_pass_no) if doc.gate_pass_no else None -%}\n\n{# --- SAFE ADDRESS EXTRACTION LOGIC (WITHOUT USING BANNED 'DO' TAG) --- #}\n{%- set full_address = \"\" -%}\n{%- if doc.supplier_address -%}\n    {%- set addr_doc = frappe.get_doc(\"Address\", doc.supplier_address) -%}\n    {%- set addr_lines = [\n        addr_doc.address_line1,\n        addr_doc.address_line2,\n        addr_doc.city,\n        addr_doc.state,\n        addr_doc.pincode,\n        addr_doc.country\n    ] -%}\n    {%- set active_lines = [] -%}\n    {%- for line in addr_lines -%}\n        {%- if line -%}\n            {%- set _ = active_lines.append(line) -%}\n        {%- endif -%}\n    {%- endfor -%}\n    {%- set full_address = active_lines|join(\", \") -%}\n{%- endif -%}\n\n<div class=\"pv-container\">\n\n    <!-- ==================================================================== -->\n    <!-- HEADER                                                               -->\n    <!-- ==================================================================== -->\n    <table class=\"pv-header-table\">\n        <tr>\n            <td class=\"pv-logo-left\">\n                {%- if silk_logo -%}\n                    <img class=\"pv-logo-img\" src=\"{{ silk_logo }}\" alt=\"SILK Logo\" />\n                {%- else -%}\n                    <span class=\"pv-font-bold pv-brand-primary\" style=\"font-size: 16px;\">SILK</span>\n                {%- endif -%}\n            </td>\n            <td class=\"pv-title-center\">\n                <div class=\"pv-title-main\">PHYSICAL VERIFICATION</div>\n                <div class=\"pv-title-sub\">Registered Vehicle Scrapping Facility (RVSF)</div>\n            </td>\n            <td class=\"pv-logo-right\">\n                {%- if rvsf_logo -%}\n                    <img class=\"pv-logo-img\" src=\"{{ rvsf_logo }}\" alt=\"RVSF Logo\" />\n                {%- else -%}\n                    <span class=\"pv-font-bold pv-brand-success\" style=\"font-size: 16px;\">RVSF</span>\n                {%- endif -%}\n            </td>\n        </tr>\n    </table>\n\n    <div class=\"pv-dashed-divider\"></div>\n\n    <!-- ==================================================================== -->\n    <!-- PHYSICAL VERIFICATION DETAILS                                        -->\n    <!-- ==================================================================== -->\n    <div class=\"pv-section-header\">Physical Verification Details</div>\n    \n    <table class=\"pv-grid-table\">\n        <tr>\n            <!-- Column 1 -->\n            <td class=\"pv-col\">\n                <table class=\"pv-data-table\">\n                    <tr>\n                        <td class=\"pv-label\">Verification No:</td>\n                        <td class=\"pv-value pv-font-bold pv-brand-primary\">{{ doc.name or \"-\" }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"pv-label\">Purchase Lead:</td>\n                        <td class=\"pv-value\">{{ doc.purchase_lead or \"-\" }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"pv-label\">Gate Pass Ref:</td>\n                        <td class=\"pv-value\">{{ doc.gate_pass_no or \"-\" }}</td>\n                    </tr>\n                </table>\n            </td>\n            <!-- Column 2 -->\n            <td class=\"pv-col\">\n                <table class=\"pv-data-table\">\n                    <tr>\n                        <td class=\"pv-label\">Date:</td>\n                        <td class=\"pv-value\">{{ frappe.utils.formatdate(doc.date) if doc.date else \"-\" }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"pv-label\">Time In:</td>\n                        <td class=\"pv-value\">{{ frappe.utils.format_time(doc.time_in) if doc.time_in else \"-\" }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"pv-label\">Company:</td>\n                        <td class=\"pv-value\">{{ doc.company or \"-\" }}</td>\n                    </tr>\n                </table>\n            </td>\n        </tr>\n    </table>\n\n    <!-- ==================================================================== -->\n    <!-- CUSTOMER DETAILS                                                     -->\n    <!-- ==================================================================== -->\n    <div class=\"pv-section-header\">Customer Details</div>\n    \n    <table class=\"pv-grid-table\">\n        <tr>\n            <!-- Column 1 -->\n            <td class=\"pv-col\">\n                <table class=\"pv-data-table\">\n                    <tr>\n                        <td class=\"pv-label\">Customer Name:</td>\n                        <td class=\"pv-value pv-font-bold\">{{ doc.owner_name or \"-\" }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"pv-label\">Contact No:</td>\n                        <td class=\"pv-value\">{{ doc.contact_number or \"-\" }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"pv-label\">PAN Card No:</td>\n                        <td class=\"pv-value\" style=\"text-transform: uppercase;\">{{ doc.pan_no or \"-\" }}</td>\n                    </tr>\n                </table>\n            </td>\n            <!-- Column 2 -->\n            <td class=\"pv-col\">\n                <table class=\"pv-data-table\">\n                    <tr>\n                        <td class=\"pv-label\">Aadhaar No:</td>\n                        <td class=\"pv-value\">\n                            {%- if doc.aadhar_no -%}\n                                [Aadhaar Redacted]\n                            {%- else -%}\n                                -\n                            {%- endif -%}\n                        </td>\n                    </tr>\n                    <tr>\n                        <td class=\"pv-label\">Address Details:</td>\n                        <td class=\"pv-value\">\n                            {%- if full_address -%}\n                                {{ full_address }}\n                            {%- else -%}\n                                {{ doc.address or \"-\" }}\n                            {%- endif -%}\n                        </td>\n                    </tr>\n                </table>\n            </td>\n        </tr>\n    </table>\n\n    <!-- ==================================================================== -->\n    <!-- VEHICLE DETAILS (INTEGRATING LINKED DOCUMENTS)                        -->\n    <!-- ==================================================================== -->\n    <div class=\"pv-section-header\">Vehicle Information</div>\n    \n    <table class=\"pv-grid-table\">\n        <tr>\n            <!-- Column 1 -->\n            <td class=\"pv-col\">\n                <table class=\"pv-data-table\">\n                    <tr>\n                        <td class=\"pv-label\">Vehicle Registration:</td>\n                        <td class=\"pv-value pv-font-bold pv-brand-success\" style=\"font-size: 11.5px;\">{{ doc.vehicle or \"-\" }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"pv-label\">Manufacturer (Maker):</td>\n                        <td class=\"pv-value\">{{ doc.maker_name or (pl_ref.maker_name if pl_ref else \"-\") }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"pv-label\">Model Name:</td>\n                        <td class=\"pv-value\">{{ doc.model_name or (pl_ref.model_name if pl_ref else \"-\") }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"pv-label\">Fuel Category:</td>\n                        <td class=\"pv-value\">{{ doc.fuel_type or (pl_ref.fuel_type if pl_ref else \"-\") }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"pv-label\">Unladen Weight (RC):</td>\n                        <td class=\"pv-value\">{{ doc.weight_at_entry_bridge_unladen_weight or (pl_ref.unladen_weight if pl_ref else \"-\") }} kg</td>\n                    </tr>\n                </table>\n            </td>\n            <!-- Column 2 -->\n            <td class=\"pv-col\">\n                <table class=\"pv-data-table\">\n                    <tr>\n                        <td class=\"pv-label\">Engine Number:</td>\n                        <td class=\"pv-value\">{{ doc.engine_number or (pl_ref.engine_number if pl_ref else \"-\") }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"pv-label\">Verified Engine No:</td>\n                        <td class=\"pv-value pv-font-bold pv-brand-secondary\">{{ doc.verfied_engine_number or \"-\" }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"pv-label\">Chassis Number:</td>\n                        <td class=\"pv-value\">{{ doc.chassis_number or (pl_ref.chassis_number if pl_ref else \"-\") }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"pv-label\">Verified Chassis No:</td>\n                        <td class=\"pv-value pv-font-bold pv-brand-secondary\">{{ doc.verified_chassis_number or \"-\" }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"pv-label\">Working Condition:</td>\n                        <td class=\"pv-value pv-font-bold\">{{ doc.working_condition or \"-\" }}</td>\n                    </tr>\n                </table>\n            </td>\n        </tr>\n    </table>\n\n    <!-- ==================================================================== -->\n    <!-- PHYSICAL INSPECTION CHILD TABLE                                      -->\n    <!-- ==================================================================== -->\n    <div class=\"pv-section-header\">Physical Condition Assessment</div>\n    \n    {%- if doc.vehicle_condition_assessment and doc.vehicle_condition_assessment|length > 0 -%}\n        <table class=\"pv-inspection-table pv-no-split\">\n            <thead>\n                <tr>\n                    <th style=\"width: 8%; text-align: center;\">S.No</th>\n                    <th style=\"width: 42%;\">Inspection Item</th>\n                    <th style=\"width: 15%; text-align: center;\">Present?</th>\n                    <th style=\"width: 20%; text-align: center;\">Condition</th>\n                    <th style=\"width: 15%; text-align: center;\">Quantity</th>\n                </tr>\n            </thead>\n            <tbody>\n                {%- for row in doc.vehicle_condition_assessment -%}\n                <tr>\n                    <td style=\"text-align: center;\">{{ row.idx }}</td>\n                    <td class=\"pv-font-bold\">{{ row.item or \"-\" }}</td>\n                    <td style=\"text-align: center;\">\n                        {%- if row.present == 1 -%}\n                            <span class=\"pv-font-bold pv-brand-success\" style=\"font-size: 11px;\">Yes</span>\n                        {%- else -%}\n                            <span style=\"color: #a0aec0;\">No</span>\n                        {%- endif -%}\n                    </td>\n                    <td style=\"text-align: center;\">\n                        <span class=\"pv-font-bold {%- if row.condition__quantity == 'Good' -%}pv-brand-success{%- elif row.condition__quantity == 'Average' -%}pv-brand-secondary{%- else -%}pv-brand-primary{%- endif -%}\">\n                            {{ row.condition__quantity or \"-\" }}\n                        </span>\n                    </td>\n                    <td style=\"text-align: center; font-weight: bold;\">{{ row.qty if row.qty is not none else \"-\" }}</td>\n                </tr>\n                {%- endfor -%}\n            </tbody>\n        </table>\n    {%- else -%}\n        <div class=\"pv-empty-state pv-no-split\">\n            No dynamic vehicle condition assessment records available.\n        </div>\n    {%- endif -%}\n\n    <!-- ==================================================================== -->\n    <!-- COMPACT INSPECTION SUMMARY CARD                                      -->\n    <!-- ==================================================================== -->\n    <div class=\"pv-summary-card pv-no-split\">\n        <table>\n            <tr>\n                <td style=\"width: 25%;\" class=\"pv-label\">Asset Tag:</td>\n                <td style=\"width: 25%;\" class=\"pv-value pv-font-bold\">{{ doc.vehicle or \"-\" }}</td>\n                <td style=\"width: 25%;\" class=\"pv-label\">Odometer Index:</td>\n                <td style=\"width: 25%;\" class=\"pv-value pv-font-bold\">{{ doc.odometer_reading or \"-\" }} Km</td>\n            </tr>\n            <tr>\n                <td class=\"pv-label\">Submission Mode:</td>\n                <td class=\"pv-value\">{{ doc.vehicle_submission_details or \"-\" }}</td>\n                <td class=\"pv-label\">Verification Time:</td>\n                <td class=\"pv-value\">\n                    {{ frappe.utils.formatdate(doc.date) if doc.date else \"-\" }} \n                    {{ frappe.utils.format_time(doc.time_in) if doc.time_in else \"\" }}\n                </td>\n            </tr>\n        </table>\n    </div>\n\n    <!-- ==================================================================== -->\n    <!-- GENERAL OBSERVATIONS (IF RECORDED)                                   -->\n    <!-- ==================================================================== -->\n    {%- if doc.details_of_authorised_person_and_letter_in_stamp_paper -%}\n        <div class=\"pv-no-split\">\n            <div class=\"pv-section-header\">Authorized Person & Stamp Details</div>\n            <div class=\"pv-observation-box\">\n                {{ doc.details_of_authorised_person_and_letter_in_stamp_paper }}\n            </div>\n        </div>\n    {%- endif -%}\n\n    <!-- ==================================================================== -->\n    <!-- OWNER'S DECLARATION & ACKNOWLEDGEMENT                                -->\n    <!-- ==================================================================== -->\n    <div class=\"pv-declaration-card pv-no-split\">\n        <div class=\"pv-font-bold pv-brand-success\" style=\"font-size: 11px; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px;\">\n            Owner's Declaration & Acknowledgement\n        </div>\n        \n        <div class=\"pv-declaration-text\">\n            I, <span class=\"pv-font-bold\">{{ doc.owner_name or \"_____________________________________\" }}</span>, hereby voluntarily surrender the aforementioned vehicle for the purpose of scrapping at STEEL INDUSTRIALS KERALA LIMITED (RVSF). I certify that the vehicle is free from all encumbrances, legal disputes, financial liabilities, or criminal cases. I understand and agree that the vehicle will be processed for scrapping in accordance with the applicable Government of India regulations and RVSF procedures.\n        </div>\n\n        <table class=\"pv-signature-container\">\n            <tr>\n                <td style=\"width: 60%; vertical-align: bottom;\">\n                    <div style=\"font-size: 10px; color: #4a5568;\">\n                        Date: ___________________________\n                    </div>\n                </td>\n                <td style=\"width: 40%; text-align: right; vertical-align: bottom;\">\n                    <div style=\"display: inline-block; text-align: center;\">\n                        {%- if doc.signature -%}\n                            <div class=\"pv-signature-img-wrap\">\n                                <img class=\"pv-signature-img\" src=\"{{ doc.signature }}\" alt=\"Customer Signature\" />\n                            </div>\n                        {%- else -%}\n                            <div style=\"height: 48px;\"></div>\n                            <div class=\"pv-signature-line\"></div>\n                        {%- endif -%}\n                        <div class=\"pv-font-bold\" style=\"font-size: 10px; color: #0b2e4f;\">Signature of Owner / Authorized Person</div>\n                    </div>\n                </td>\n            </tr>\n        </table>\n    </div>\n\n    <!-- ==================================================================== -->\n    <!-- VERIFICATION APPROVAL COLUMNS (INTERNAL RECORDING)                   -->\n    <!-- ==================================================================== -->\n    <div class=\"pv-no-split\" style=\"margin-top: 15px;\">\n        <div class=\"pv-section-header\" style=\"background-color: #123a63;\">Verification Approval</div>\n        \n        <table class=\"pv-approval-table\">\n            <tr>\n                <!-- Prepared By -->\n                <td>\n                    <div class=\"pv-approval-title\">Prepared By</div>\n                    <div class=\"pv-approval-name\">{{ doc.inspected_by_name or doc.owner or \"-\" }}</div>\n                    <div style=\"height: 25px;\"></div>\n                    <div class=\"pv-approval-sign-line\"></div>\n                    <div class=\"pv-approval-sign-label\">(Signature)</div>\n                </td>\n                \n                <!-- Verified By -->\n                <td>\n                    <div class=\"pv-approval-title\">Verified By</div>\n                    <div class=\"pv-approval-name\">{{ doc.verified_by_name or \"Pending Verification\" }}</div>\n                    <div style=\"height: 25px;\"></div>\n                    <div class=\"pv-approval-sign-line\"></div>\n                    <div class=\"pv-approval-sign-label\">(Signature)</div>\n                </td>\n                \n                <!-- Authorized By -->\n                <td>\n                    <div class=\"pv-approval-title\">Authorized By</div>\n                    <div class=\"pv-approval-name\">{{ doc.authorized_by_name or \"Pending Authorization\" }}</div>\n                    <div style=\"height: 25px;\"></div>\n                    <div class=\"pv-approval-sign-line\"></div>\n                    <div class=\"pv-approval-sign-label\">(Signature)</div>\n                </td>\n            </tr>\n        </table>\n    </div>\n\n</div>",
