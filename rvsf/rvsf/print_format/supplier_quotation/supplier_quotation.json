 "doc_type": "Supplier Quotation",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<style>\n  /* ===================== BASE ===================== */\n  #supplier-quotation-print {\n    font-family: \"Helvetica Neue\", Arial, \"Segoe UI\", sans-serif;\n    color: #1f2933;\n    font-size: 10.5px;\n    line-height: 1.45;\n    background: #ffffff;\n    -webkit-print-color-adjust: exact;\n    print-color-adjust: exact;\n  }\n\n  #supplier-quotation-print * { box-sizing: border-box; }\n\n  #supplier-quotation-print table {\n    border-collapse: collapse;\n    width: 100%;\n    table-layout: fixed;\n  }\n\n  @page { size: A4; margin: 14mm 12mm; }\n\n  /* ===================== HEADER ===================== */\n  .sq-header {\n    border-bottom: 3px solid #0b2e4f;\n    padding-bottom: 10px;\n    margin-bottom: 10px;\n  }\n  .sq-header table { table-layout: auto; }\n  .sq-header-cell { vertical-align: middle; padding: 0; }\n  .sq-brand-left  { width: 26%; text-align: left; }\n  .sq-brand-mid   { width: 48%; text-align: center; white-space: nowrap; }\n  .sq-brand-right { width: 26%; text-align: right; }\n\n  .sq-logo-silk {\n    height: 46px !important;\n    width: auto !important;\n    max-width: 160px !important;\n    max-height: 46px !important;\n    display: inline-block;\n  }\n  .sq-logo-rvsf {\n    height: 34px !important;\n    width: auto !important;\n    max-width: 140px !important;\n    max-height: 34px !important;\n    display: inline-block;\n  }\n\n  .sq-doc-title {\n    font-size: 19px;\n    font-weight: 800;\n    color: #1b5e20;\n    text-transform: uppercase;\n    letter-spacing: 0.8px;\n    white-space: nowrap;\n  }\n  .sq-doc-subtitle {\n    font-size: 9px;\n    color: #55606b;\n    margin-top: 2px;\n    text-transform: uppercase;\n    letter-spacing: 0.4px;\n    white-space: nowrap;\n  }\n  .sq-doc-subtitle .sq-company-inline {\n    color: #123a63;\n    font-weight: 700;\n  }\n\n  /* ===================== SECTIONS ===================== */\n  .sq-section { margin-bottom: 12px; }\n  .sq-section-header {\n    background-color: #123a63;\n    background-image: linear-gradient(90deg, #0b2e4f 0%, #123a63 70%, #1b5e20 100%);\n    color: #fff;\n    padding: 5px 12px;\n    border-radius: 5px;\n    font-size: 10.5px;\n    font-weight: 700;\n    letter-spacing: 0.4px;\n    text-transform: uppercase;\n    margin-bottom: 6px;\n  }\n\n  /* ===================== FIELD GRID (label / value rows) ===================== */\n  .sq-field-grid {\n    border: 1px solid #d9dde3;\n    border-radius: 4px;\n  }\n  .sq-field-grid tr:nth-child(even) td { background: #f6f8fa; }\n  .sq-field-cell {\n    padding: 5px 10px;\n    border-bottom: 1px solid #d9dde3;\n    vertical-align: top;\n    width: 50%;\n  }\n  .sq-field-grid tr:last-child .sq-field-cell { border-bottom: none; }\n  .sq-field-label {\n    font-weight: 700;\n    color: #0b2e4f;\n    display: inline-block;\n    min-width: 2%;\n    font-size: 9.7px;\n  }\n  .sq-field-value {\n    color: #1f2933;\n    font-size: 10px;\n  }\n  .sq-field-value.empty { color: #9aa5b1; font-style: italic; }\n\n  /* single-column field row (used for supplier address) */\n  .sq-field-cell.full { width: 100%; }\n\n  /* ===================== PURCHASE PROPOSED AMOUNT (MINIMAL) ===================== */\n  .sq-amount-box {\n    border: 1.5px solid #1b5e20;\n    border-radius: 4px;\n    background: #e8f3e9;\n    padding: 10px 16px;\n  }\n  .sq-amount-label {\n    color: #1b5e20;\n    font-size: 9px;\n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    margin-bottom: 3px;\n  }\n  .sq-amount-value {\n    color: #1b5e20;\n    font-size: 21px;\n    font-weight: 800;\n    letter-spacing: 0.2px;\n  }\n\n  /* ===================== DECLARATION BOX ===================== */\n  .sq-declaration-box {\n    border: 1px solid #d9dde3;\n    border-left: 4px solid #123a63;\n    border-radius: 4px;\n    background: #f6f8fa;\n    padding: 10px 14px;\n    font-size: 9.8px;\n    color: #333f4a;\n    line-height: 1.6;\n  }\n\n  /* ===================== SIGNATURE BLOCKS ===================== */\n  .sq-signature-box {\n    border: 1px solid #d9dde3;\n    border-radius: 4px;\n    padding: 10px 14px;\n  }\n  .sq-signature-image {\n    max-height: 60px !important;\n    max-width: 220px !important;\n    height: auto !important;\n    width: auto !important;\n    display: block;\n    margin-bottom: 6px;\n  }\n  .sq-signature-line {\n    border-top: 1px solid #1f2933;\n    width: 220px;\n    margin-top: 40px;\n    margin-bottom: 4px;\n  }\n  .sq-signature-placeholder {\n    font-size: 10px;\n    color: #55606b;\n    margin-top: 30px;\n    margin-bottom: 4px;\n  }\n  .sq-signature-caption {\n    font-size: 9px;\n    font-weight: 700;\n    color: #0b2e4f;\n    text-transform: uppercase;\n    letter-spacing: 0.3px;\n  }\n\n  /* keep sections from splitting awkwardly across a PDF page break */\n  .sq-avoid-break { page-break-inside: avoid; }\n</style>\n\n{%- set silk_logo = frappe.db.get_value(\"File\", {\"file_name\": \"image5.jpg\"}, \"file_url\") -%}\n{%- set rvsf_logo = frappe.db.get_value(\"File\", {\"file_name\": \"image1.jpg\"}, \"file_url\") -%}\n{%- set first_item = doc.items[0] if doc.items else None -%}\n{%- set customer_sign = doc.get(\"custom_customer_sign\") -%}\n{%- set purchase_lead = frappe.db.get_value(\"Purchase Lead\", doc.get(\"custom_purchase_lead\"), [\"maker_name\", \"model_name\", \"vehicle_category\", \"vehicle_registration_no\"], as_dict=True) if doc.get(\"custom_purchase_lead\") else None -%}\n{%- set vehicle_reg_no = doc.vehicle_registration_no or (purchase_lead.vehicle_registration_no if purchase_lead else None) or (first_item.get(\"vehicle_registration_no\") if first_item else None) -%}\n\n<div id=\"supplier-quotation-print\">\n\n  <!-- ============================================================ -->\n  <!-- HEADER                                                        -->\n  <!-- ============================================================ -->\n  <div class=\"sq-header sq-avoid-break\">\n    <table>\n      <tr>\n        <td class=\"sq-header-cell sq-brand-left\">\n          <img class=\"sq-logo-silk\" src=\"{{ silk_logo or '/files/image5.jpg' }}\" width=\"120\" height=\"46\">\n        </td>\n        <td class=\"sq-header-cell sq-brand-mid\">\n          <div class=\"sq-doc-title\">Supplier Quotation</div>\n          <div class=\"sq-doc-subtitle\">Registered Vehicle Scrapping Facility (RVSF){% if doc.company %} &middot; <span class=\"sq-company-inline\">{{ doc.company }}</span>{% endif %}</div>\n        </td>\n        <td class=\"sq-header-cell sq-brand-right\">\n          <img class=\"sq-logo-rvsf\" src=\"{{ rvsf_logo or '/files/image1.jpg' }}\" alt=\"RVSF\" width=\"105\" height=\"34\">\n        </td>\n      </tr>\n    </table>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- QUOTATION DETAILS                                             -->\n  <!-- ============================================================ -->\n  <div class=\"sq-section sq-avoid-break\">\n    <div class=\"sq-section-header\">Quotation Details</div>\n    <table class=\"sq-field-grid\">\n      <tr>\n        <td class=\"sq-field-cell\"><span class=\"sq-field-label\">Quotation No:</span>\n          <span class=\"sq-field-value\">{{ doc.name or \"-\" }}</span>\n        </td>\n        <td class=\"sq-field-cell\"><span class=\"sq-field-label\">Purchase Lead Ref:</span>\n          <span class=\"sq-field-value {{ 'empty' if not doc.get('custom_purchase_lead') }}\">{{ doc.get(\"custom_purchase_lead\") or \"Not linked\" }}</span>\n        </td>\n      </tr>\n      <tr>\n        <td class=\"sq-field-cell\"><span class=\"sq-field-label\">Company:</span>\n          <span class=\"sq-field-value {{ 'empty' if not doc.company }}\">{{ doc.company or \"Not specified\" }}</span>\n        </td>\n        <td class=\"sq-field-cell\"><span class=\"sq-field-label\">Date:</span>\n          <span class=\"sq-field-value\">{{ frappe.utils.formatdate(doc.transaction_date) if doc.transaction_date else \"-\" }}</span>\n        </td>\n      </tr>\n    </table>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- SUPPLIER DETAILS                                              -->\n  <!-- ============================================================ -->\n  {% set address = frappe.get_all(\n    \"Dynamic Link\",\n    filters={\n        \"link_doctype\": \"Supplier\",\n        \"link_name\": doc.supplier,\n        \"parenttype\": \"Address\"\n    },\n    fields=[\"parent\"],\n    limit=1\n) %}\n\n{% if address %}\n    {% set addr = frappe.get_doc(\"Address\", address[0].parent) %}\n{% endif %}\n  <div class=\"sq-section sq-avoid-break\">\n    <div class=\"sq-section-header\">Supplier Details</div>\n\n    <table class=\"sq-field-grid\">\n        <tr>\n            <td class=\"sq-field-cell\">\n                <span class=\"sq-field-label\">Supplier Name:</span>\n                <span class=\"sq-field-value\">{{ doc.supplier_name or doc.supplier }}</span>\n            </td>\n\n            <td class=\"sq-field-cell\">\n                <span class=\"sq-field-label\">Contact No:</span>\n                <span class=\"sq-field-value\">{{ addr.phone or \"-\" }}</span>\n            </td>\n        </tr>\n\n        <tr>\n            <td class=\"sq-field-cell full\" colspan=\"2\">\n                <span class=\"sq-field-label\">Address:</span>\n                <span class=\"sq-field-value\">\n                    {{ addr.address_line1 or \"\" }}\n                    {% if addr.address_line2 %}, {{ addr.address_line2 }}{% endif %}\n                </span>\n            </td>\n        </tr>\n\n        <tr>\n            <td class=\"sq-field-cell\">\n                <span class=\"sq-field-label\">District:</span>\n                <span class=\"sq-field-value\">{{ addr.city or \"-\" }}</span>\n            </td>\n\n            <td class=\"sq-field-cell\">\n                <span class=\"sq-field-label\">State:</span>\n                <span class=\"sq-field-value\">{{ addr.state or \"-\" }}</span>\n            </td>\n        </tr>\n\n        <tr>\n            <td class=\"sq-field-cell\">\n                <span class=\"sq-field-label\">PIN Code:</span>\n                <span class=\"sq-field-value\">{{ addr.pincode or \"-\" }}</span>\n            </td>\n\n            <td class=\"sq-field-cell\"></td>\n        </tr>\n    </table>\n</div>\n  <!-- ============================================================ -->\n  <!-- VEHICLE DETAILS                                               -->\n  <!-- ============================================================ -->\n  <div class=\"sq-section sq-avoid-break\">\n    <div class=\"sq-section-header\">Vehicle Details</div>\n    <table class=\"sq-field-grid\">\n      <tr>\n        <td class=\"sq-field-cell\"><span class=\"sq-field-label\">Registration No:</span>\n          <span class=\"sq-field-value {{ 'empty' if not vehicle_reg_no }}\">{{ vehicle_reg_no or \"Not available\" }}</span>\n        </td>\n        <td class=\"sq-field-cell\"><span class=\"sq-field-label\">Maker Name:</span>\n          <span class=\"sq-field-value {{ 'empty' if not (purchase_lead and purchase_lead.maker_name) }}\">{{ purchase_lead.maker_name if purchase_lead and purchase_lead.maker_name else \"Not specified\" }}</span>\n        </td>\n      </tr>\n      <tr>\n        <td class=\"sq-field-cell\"><span class=\"sq-field-label\">Model Name:</span>\n          <span class=\"sq-field-value {{ 'empty' if not (purchase_lead and purchase_lead.model_name) }}\">{{ purchase_lead.model_name if purchase_lead and purchase_lead.model_name else \"Not specified\" }}</span>\n        </td>\n        <td class=\"sq-field-cell\"><span class=\"sq-field-label\">Vehicle Category:</span>\n          <span class=\"sq-field-value {{ 'empty' if not (purchase_lead and purchase_lead.vehicle_category) }}\">{{ purchase_lead.vehicle_category if purchase_lead and purchase_lead.vehicle_category else \"Not specified\" }}</span>\n        </td>\n      </tr>\n    </table>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- PURCHASE PROPOSED AMOUNT                                      -->\n  <!-- ============================================================ -->\n  <div class=\"sq-section sq-avoid-break\">\n    <div class=\"sq-amount-box\">\n      <div class=\"sq-amount-label\">Purchase Proposed Amount</div>\n      <div class=\"sq-amount-value\">{{ frappe.utils.fmt_money(doc.grand_total, currency=doc.currency) }}</div>\n    </div>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- DECLARATION                                                   -->\n  <!-- ============================================================ -->\n  <div class=\"sq-section sq-avoid-break\">\n    <div class=\"sq-section-header\">Declaration</div>\n    <div class=\"sq-declaration-box\">\n      We are pleased to offer the above quotation for the purchase of your End-of-Life Vehicle (ELV). Kindly review the proposed amount and, if acceptable, provide your signature as confirmation of acceptance. Further processing will be carried out after successful verification of the vehicle and supporting documents in accordance with RVSF procedures.\n    </div>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- CUSTOMER ACCEPTANCE                                           -->\n  <!-- ============================================================ -->\n  <div class=\"sq-section sq-avoid-break\">\n    <div class=\"sq-section-header\">Customer Acceptance</div>\n    <div class=\"sq-signature-box\">\n      {% if customer_sign %}\n        <img class=\"sq-signature-image\" src=\"{{ customer_sign }}\">\n        <div class=\"sq-signature-caption\">Customer Signature</div>\n      {% else %}\n        <div class=\"sq-signature-placeholder\">Customer Signature: ______________________</div>\n      {% endif %}\n    </div>\n  </div>\n\n</div>",
