{
 "absolute_value": 0,
 "align_labels_right": 0,
 "creation": "2026-07-16 15:20:04.080316",
 "custom_format": 1,
 "default_print_language": "en",
 "disabled": 0,
 "doc_type": "Purchase Lead",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<style>\n  /* ===================== BASE ===================== */\n  #purchase-lead-print {\n    font-family: \"Helvetica Neue\", Arial, \"Segoe UI\", sans-serif;\n    color: #1f2933;\n    font-size: 10.5px;\n    line-height: 1.45;\n    background: #ffffff;\n    -webkit-print-color-adjust: exact;\n    print-color-adjust: exact;\n  }\n\n  #purchase-lead-print * { box-sizing: border-box; }\n\n  #purchase-lead-print table {\n    border-collapse: collapse;\n    width: 100%;\n    table-layout: fixed;\n  }\n\n  @page { size: A4; margin: 14mm 12mm; }\n\n  /* ===================== HEADER ===================== */\n  .pl-header {\n    border-bottom: 3px solid #0b2e4f;\n    padding-bottom: 10px;\n    margin-bottom: 10px;\n  }\n  .pl-header table { table-layout: auto; }\n  .pl-header-cell { vertical-align: middle; padding: 0; }\n  .pl-brand-left  { width: 32%; text-align: left; }\n  .pl-brand-mid   { width: 36%; text-align: center; }\n  .pl-brand-right { width: 32%; text-align: right; }\n\n  .pl-logo-silk {\n    height: 46px !important;\n    width: auto !important;\n    max-width: 160px !important;\n    max-height: 46px !important;\n    display: inline-block;\n  }\n  .pl-logo-rvsf {\n    height: 34px !important;\n    width: auto !important;\n    max-width: 140px !important;\n    max-height: 34px !important;\n    display: inline-block;\n  }\n\n  .pl-company-name {\n    font-size: 17px;\n    font-weight: 700;\n    color: #0b2e4f;\n    letter-spacing: 0.3px;\n    margin-top: 4px;\n  }\n  .pl-doc-title {\n    font-size: 20px;\n    font-weight: 800;\n    color: #1b5e20;\n    text-transform: uppercase;\n    letter-spacing: 1px;\n  }\n  .pl-doc-subtitle {\n    font-size: 9.5px;\n    color: #55606b;\n    margin-top: 2px;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n  }\n  .pl-rvsf-tag {\n    display: inline-block;\n    margin-top: 5px;\n    font-size: 9px;\n    font-weight: 700;\n    color: #1b5e20;\n    background: #e8f3e9;\n    border: 1px solid #2e7d32;\n    border-radius: 10px;\n    padding: 2px 10px;\n    letter-spacing: 0.4px;\n  }\n\n  /* ===================== META STRIP (PL No / Date / Status) ===================== */\n  .pl-meta-strip {\n    background: #eaf1f8;\n    border: 1px solid #d9dde3;\n    border-radius: 6px;\n    margin-bottom: 14px;\n  }\n  .pl-meta-cell {\n    padding: 7px 12px;\n    border-right: 1px solid #d9dde3;\n    vertical-align: middle;\n    width: 25%;\n  }\n  .pl-meta-cell.last { border-right: none; }\n  .pl-meta-label {\n    font-size: 8px;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    color: #55606b;\n    font-weight: 700;\n    margin-bottom: 2px;\n  }\n  .pl-meta-value {\n    font-size: 11px;\n    font-weight: 700;\n    color: #0b2e4f;\n  }\n  .pl-status-badge {\n    display: inline-block;\n    padding: 2px 10px;\n    border-radius: 10px;\n    font-size: 9.5px;\n    font-weight: 700;\n    color: #fff;\n    background: #1b5e20;\n  }\n  .status-Open, .status-Revised            { background: #8a6d00; }\n  .status-Accepted, .status-Completed      { background: #1b5e20; }\n  .status-Rejected                         { background: #8e2020; }\n  .status-Quotation-Sent                   { background: #123a63; }\n  .status-Ready-For-Certification          { background: #b8860b; }\n\n  /* ===================== SECTIONS ===================== */\n  .pl-section { margin-bottom: 12px; }\n  .pl-section-header {\n    background-color: #123a63;\n    background-image: linear-gradient(90deg, #0b2e4f 0%, #123a63 70%, #1b5e20 100%);\n    color: #fff;\n    padding: 5px 12px;\n    border-radius: 5px;\n    font-size: 10.5px;\n    font-weight: 700;\n    letter-spacing: 0.4px;\n    text-transform: uppercase;\n    margin-bottom: 6px;\n  }\n\n  /* ===================== FIELD GRID (label / value rows) ===================== */\n  .pl-field-grid {\n    border: 1px solid #d9dde3;\n    border-radius: 4px;\n  }\n  .pl-field-grid tr:nth-child(even) td { background: #f6f8fa; }\n  .pl-field-cell {\n    padding: 5px 10px;\n    border-bottom: 1px solid #d9dde3;\n    vertical-align: top;\n    width: 50%;\n  }\n  .pl-field-grid tr:last-child .pl-field-cell { border-bottom: none; }\n  .pl-field-label {\n    font-weight: 700;\n    color: #0b2e4f;\n    display: inline-block;\n    min-width: 5%;\n    font-size: 9.7px;\n  }\n  .pl-field-value {\n    color: #1f2933;\n    font-size: 10px;\n  }\n  .pl-field-value.empty { color: #9aa5b1; font-style: italic; }\n\n  /* ===================== VERIFICATION CHECKS ===================== */\n  .pl-check-grid { table-layout: fixed; }\n  .pl-check-cell {\n    width: 33.33%;\n    padding: 8px 10px;\n    border: 1px solid #d9dde3;\n    text-align: center;\n    vertical-align: middle;\n  }\n  .pl-check-label {\n    display: block;\n    font-size: 9.3px;\n    font-weight: 700;\n    color: #0b2e4f;\n    margin-bottom: 4px;\n    text-transform: uppercase;\n    letter-spacing: 0.3px;\n  }\n  .pl-check-badge {\n    display: inline-block;\n    padding: 2px 14px;\n    border-radius: 10px;\n    font-size: 9.5px;\n    font-weight: 800;\n    color: #fff;\n  }\n  .pl-check-yes { background: #1b5e20; }\n  .pl-check-no  { background: #8e2020; }\n\n  /* ===================== CHILD TABLE ===================== */\n  .pl-table {\n    width: 100%;\n    table-layout: auto;\n    border-collapse: collapse;\n    font-size: 9.7px;\n  }\n  .pl-table th {\n    background: #0b2e4f;\n    color: #fff;\n    text-align: left;\n    padding: 6px 8px;\n    font-size: 9px;\n    text-transform: uppercase;\n    letter-spacing: 0.3px;\n    border: 1px solid #0b2e4f;\n  }\n  .pl-table td {\n    padding: 5px 8px;\n    border: 1px solid #d9dde3;\n    vertical-align: top;\n    word-break: break-word;\n  }\n  .pl-table tr:nth-child(even) td { background: #f6f8fa; }\n  .pl-table td.center { text-align: center; }\n  .pl-empty-note {\n    padding: 8px 10px;\n    border: 1px dashed #d9dde3;\n    color: #55606b;\n    font-style: italic;\n    font-size: 9.5px;\n    border-radius: 4px;\n  }\n\n  /* ===================== ADDRESS SECTION ===================== */\n  .pl-address-box {\n    border: 1px solid #d9dde3;\n    border-radius: 4px;\n  }\n  .pl-address-box tr:nth-child(even) td { background: #f6f8fa; }\n  .pl-address-box td {\n    padding: 6px 10px;\n    border-bottom: 1px solid #d9dde3;\n    vertical-align: top;\n  }\n  .pl-address-box tr:last-child td { border-bottom: none; }\n  .pl-address-label {\n    width: 85px;\n    font-weight: 700;\n    color: #0b2e4f;\n    font-size: 9.7px;\n    white-space: nowrap;\n  }\n  .pl-address-value {\n    color: #1f2933;\n    font-size: 10px;\n    word-break: break-word;\n  }\n  .pl-address-value.empty { color: #9aa5b1; font-style: italic; }\n\n  /* ===================== FOOTER ===================== */\n  .pl-footer {\n    margin-top: 22px;\n    border-top: 2px solid #0b2e4f;\n    padding-top: 10px;\n  }\n  .pl-sign-grid { margin-bottom: 10px; }\n  .pl-sign-cell {\n    width: 33.33%;\n    text-align: center;\n    padding-top: 26px;\n    vertical-align: bottom;\n  }\n  .pl-sign-line {\n    border-top: 1px solid #1f2933;\n    margin: 0 14px 4px 14px;\n  }\n  .pl-sign-label {\n    font-size: 9px;\n    font-weight: 700;\n    color: #0b2e4f;\n    text-transform: uppercase;\n    letter-spacing: 0.3px;\n  }\n  .pl-footer-bottom {\n    border-top: 1px solid #d9dde3;\n    padding-top: 6px;\n    font-size: 8.3px;\n    color: #55606b;\n  }\n  .pl-footer-bottom-cell { vertical-align: middle; padding: 0; }\n  .pl-footer-left  { width: 60%; text-align: left; }\n  .pl-footer-right { width: 40%; text-align: right; }\n  .pl-footer-brand { font-weight: 700; color: #1b5e20; }\n\n  /* keep sections from splitting awkwardly across a PDF page break */\n  .pl-avoid-break { page-break-inside: avoid; }\n</style>\n\n<div id=\"purchase-lead-print\">\n\n  <!-- ============================================================ -->\n  <!-- HEADER                                                        -->\n  <!-- ============================================================ -->\n  <div class=\"pl-header pl-avoid-break\">\n    <table>\n      <tr>\n        <td class=\"pl-header-cell pl-brand-left\">\n          <img class=\"pl-logo-silk\" src=\"/files/image5.jpg\" width=\"120\" height=\"46\">\n          <div class=\"pl-company-name\">{{ doc.company or \"SILK\" }}</div>\n        </td>\n        <td class=\"pl-header-cell pl-brand-mid\">\n          <div class=\"pl-doc-title\">Purchase Lead</div>\n          <div class=\"pl-doc-subtitle\">Registered Vehicle Scrapping Facility</div>\n          <div class=\"pl-rvsf-tag\">RVSF Department</div>\n        </td>\n        <td class=\"pl-header-cell pl-brand-right\">\n          <img class=\"pl-logo-rvsf\" src=\"/files/image1.jpg\" alt=\"RVSF\" width=\"105\" height=\"34\">\n        </td>\n      </tr>\n    </table>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- META STRIP                                                    -->\n  <!-- ============================================================ -->\n  <table class=\"pl-meta-strip pl-avoid-break\">\n    <tr>\n      <td class=\"pl-meta-cell\">\n        <div class=\"pl-meta-label\">Purchase Lead No</div>\n        <div class=\"pl-meta-value\">{{ doc.name or \"-\" }}</div>\n      </td>\n      <td class=\"pl-meta-cell\">\n        <div class=\"pl-meta-label\">Vehicle Registration No:</div>\n        <div class=\"pl-meta-value\">{{ doc.vehicle_registration_no or \"-\" }}</div>\n      </td>\n      <td class=\"pl-meta-cell\">\n        <div class=\"pl-meta-label\">Date</div>\n        <div class=\"pl-meta-value\">{{ frappe.utils.formatdate(doc.creation) if doc.creation else \"-\" }}</div>\n      </td>\n      <td class=\"pl-meta-cell last\">\n        <div class=\"pl-meta-label\">Status</div>\n        <div class=\"pl-meta-value\">\n          <span class=\"pl-status-badge status-{{ (doc.status or 'Open') | replace(' ', '-') }}\">{{ doc.status or \"Open\" }}</span>\n        </div>\n      </td>\n    </tr>\n  </table>\n\n  <!-- ============================================================ -->\n  <!-- SECTION: APPLICATION / REGISTRATION DETAILS                   -->\n  <!-- ============================================================ -->\n  <div class=\"pl-section pl-avoid-break\">\n    <div class=\"pl-section-header\">Application &amp; Registration Details</div>\n    <table class=\"pl-field-grid\">\n      <tr>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Application Type:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.application_type }}\">{{ doc.application_type or \"Not specified\" }}</span>\n        </td>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Application No (V-Scrap):</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.application_no }}\">{{ doc.application_no or \"Not specified\" }}</span>\n        </td>\n      </tr>\n      {% if doc.application_type == \"Direct Customer\" %}\n      <tr>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Entry Pass:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.entry_pass }}\">{{ doc.entry_pass or \"Not specified\" }}</span>\n        </td>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Cost Center:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.cost_center }}\">{{ doc.cost_center or \"Not specified\" }}</span>\n        </td>\n      </tr>\n      {% else %}\n      <tr>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Cost Center:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.cost_center }}\">{{ doc.cost_center or \"Not specified\" }}</span>\n        </td>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Ownership Type:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.ownership_type }}\">{{ doc.ownership_type or \"Private\" }}</span>\n        </td>\n      </tr>\n      {% endif %}\n      {% if doc.supplier %}\n      <tr>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Supplier:</span>\n          <span class=\"pl-field-value\">{{ doc.supplier }}</span>\n        </td>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Ownership Type:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.ownership_type }}\">{{ doc.ownership_type or \"Private\" }}</span>\n        </td>\n      </tr>\n      {% endif %}\n    </table>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- SECTION: VEHICLE INFORMATION                                  -->\n  <!-- ============================================================ -->\n  <div class=\"pl-section pl-avoid-break\">\n    <div class=\"pl-section-header\">Vehicle Information</div>\n    <table class=\"pl-field-grid\">\n      <tr>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Maker Name:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.maker_name }}\">{{ doc.maker_name or \"Not specified\" }}</span>\n        </td>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Model Name:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.model_name }}\">{{ doc.model_name or \"Not specified\" }}</span>\n        </td>\n      </tr>\n      <tr>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Vehicle Category:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.vehicle_category }}\">{{ doc.vehicle_category or \"Not specified\" }}</span>\n        </td>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Fuel Type:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.fuel_type }}\">{{ doc.fuel_type or \"Not specified\" }}</span>\n        </td>\n      </tr>\n      <tr>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Chassis No:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.chassis_no }}\">{{ doc.chassis_no or \"Not provided\" }}</span>\n        </td>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Engine No:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.engine_no }}\">{{ doc.engine_no or \"Not provided\" }}</span>\n        </td>\n      </tr>\n      <tr>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Month/Year of Manufacture:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.monthyear_of_manufacture }}\">{{ doc.monthyear_of_manufacture or \"Not provided\" }}</span>\n        </td>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Unladen Weight (RC):</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.rc_weight }}\">{{ \"%.2f\"|format(doc.rc_weight) if doc.rc_weight else \"Not provided\" }} kg</span>\n        </td>\n      </tr>\n      <tr>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">State Name:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.state_name }}\">{{ doc.state_name or \"Not provided\" }}</span>\n        </td>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">RTO Name:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.rto_name }}\">{{ doc.rto_name or \"Not provided\" }}</span>\n        </td>\n      </tr>\n      <tr>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Norms:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.norms }}\">{{ doc.norms or \"Not specified\" }}</span>\n        </td>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">HSN/SAC Code:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.gst_hsn_code }}\">{{ doc.gst_hsn_code or \"72044900\" }}</span>\n        </td>\n      </tr>\n    </table>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- SECTION: OWNER DETAILS                                        -->\n  <!-- ============================================================ -->\n  <div class=\"pl-section pl-avoid-break\">\n    <div class=\"pl-section-header\">Owner Details</div>\n    <table class=\"pl-field-grid\">\n      <tr>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Owner Name:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.owner_name }}\">{{ doc.owner_name or \"Not specified\" }}</span>\n        </td>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Mobile Number:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.mobile_number }}\">{{ doc.mobile_number or \"Not specified\" }}</span>\n        </td>\n      </tr>\n      <tr>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Email ID:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.email_id }}\">{{ doc.email_id or \"Not specified\" }}</span>\n        </td>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">PAN Number:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.pan_number }}\">{{ doc.pan_number or \"Not provided\" }}</span>\n        </td>\n      </tr>\n      <tr>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Aadhar No:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.aadhar_no }}\">{{ doc.aadhar_no or \"Not provided\" }}</span>\n        </td>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Vehicle to be Deposited By:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.vehicle_to_be_deposited_by }}\">{{ doc.vehicle_to_be_deposited_by or \"Not specified\" }}</span>\n        </td>\n      </tr>\n    </table>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- SECTION: ADDRESS INFORMATION                                  -->\n  <!-- ============================================================ -->\n  <div class=\"pl-section pl-avoid-break\">\n    <div class=\"pl-section-header\">Address Information</div>\n    <table class=\"pl-address-box\">\n      <colgroup>\n        <col style=\"width:85px\">\n        <col>\n      </colgroup>\n      <tr>\n        <td class=\"pl-address-label\">Address:</td>\n        <td class=\"pl-address-value\">\n          {%- set addr_parts = [] -%}\n          {%- if doc.address1 %}{% set _ = addr_parts.append(doc.address1) %}{% endif -%}\n          {%- if doc.address2 %}{% set _ = addr_parts.append(doc.address2) %}{% endif -%}\n          {%- if doc.address3 %}{% set _ = addr_parts.append(doc.address3) %}{% endif -%}\n          {{ addr_parts | join(\", \") if addr_parts else \"Not provided\" }}\n        </td>\n      </tr>\n      <tr>\n        <td class=\"pl-address-label\">State:</td>\n        <td class=\"pl-address-value {{ 'empty' if not doc.state }}\">\n          {{ doc.state or \"Not provided\" }}\n        </td>\n      </tr>\n      <tr>\n        <td class=\"pl-address-label\">District:</td>\n        <td class=\"pl-address-value {{ 'empty' if not doc.district }}\">\n          {{ doc.district or \"Not provided\" }}\n        </td>\n      </tr>\n      <tr>\n        <td class=\"pl-address-label\">Pin Code:</td>\n        <td class=\"pl-address-value {{ 'empty' if not doc.pin_code }}\">\n          {{ doc.pin_code or \"Not provided\" }}\n        </td>\n      </tr>\n    </table>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- SECTION: VERIFICATION / VEHICLE CHECK                         -->\n  <!-- ============================================================ -->\n  <div class=\"pl-section pl-avoid-break\">\n    <div class=\"pl-section-header\">Verification Details</div>\n    <table class=\"pl-check-grid\">\n      <tr>\n        <td class=\"pl-check-cell\">\n          <span class=\"pl-check-label\">No Hypothecation</span>\n          <span class=\"pl-check-badge {{ 'pl-check-yes' if doc.no_hypothecation else 'pl-check-no' }}\">\n            {{ \"CONFIRMED\" if doc.no_hypothecation else \"PENDING\" }}\n          </span>\n        </td>\n        <td class=\"pl-check-cell\">\n          <span class=\"pl-check-label\">NCRB Clearance</span>\n          <span class=\"pl-check-badge {{ 'pl-check-yes' if doc.ncrb_clearance else 'pl-check-no' }}\">\n            {{ \"CONFIRMED\" if doc.ncrb_clearance else \"PENDING\" }}\n          </span>\n        </td>\n        <td class=\"pl-check-cell\">\n          <span class=\"pl-check-label\">Not Black Listed</span>\n          <span class=\"pl-check-badge {{ 'pl-check-yes' if doc.not_black_listed else 'pl-check-no' }}\">\n            {{ \"CONFIRMED\" if doc.not_black_listed else \"PENDING\" }}\n          </span>\n        </td>\n      </tr>\n    </table>\n  </div>\n\n  <!-- ============================================================ -->\n  <!-- SECTION: BANK / PAYMENT ACCOUNT DETAILS                       -->\n  <!-- ============================================================ -->\n  <div class=\"pl-section pl-avoid-break\">\n    <div class=\"pl-section-header\">Account Details for Payment Transfer by Scrapping Center</div>\n    <table class=\"pl-field-grid\">\n      <tr>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Bank Name:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.bank_name }}\">{{ doc.bank_name or \"Not provided\" }}</span>\n        </td>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Branch:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.branch }}\">{{ doc.branch or \"Not provided\" }}</span>\n        </td>\n      </tr>\n      <tr>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">Account Number:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.account_number }}\">{{ doc.account_number or \"Not provided\" }}</span>\n        </td>\n        <td class=\"pl-field-cell\"><span class=\"pl-field-label\">IFSC Code:</span>\n          <span class=\"pl-field-value {{ 'empty' if not doc.ifsc }}\">{{ doc.ifsc or \"Not provided\" }}</span>\n        </td>\n      </tr>\n    </table>\n  </div>\n\n</div>",
